projection;
strict ( 2 );
use draft;

define behavior for ZCIT_APPT_HC_IT18 alias AppointmentHdr
{
  use create;
  use update;
  use delete;
  use action Edit;
  use action Activate;
  use action Discard;
  use action Prepare;
  use action Resume;
  use association _appointmentitem { create; with draft; }
}

define behavior for ZCIT_APPT_IC_IT18 alias AppointmentItm
{
  use update;
  use delete;
  use association _appointmentHeader { with draft; }
}